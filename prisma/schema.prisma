generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER @map("user")
  DEMO @map("demo")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())

  products Product[]
}

model Product {
  id        String   @id @default(uuid())
  userId    String
  name      String
  category  String?
  createdAt DateTime @default(now())

  user           User             @relation(fields: [userId], references: [id])
  reviews        Review[]
  sales          Sales[]
  predictions    Prediction[]
  insights       Insight[]
  KeywordSummary KeywordSummary[]
}

model Review {
  id         String   @id @default(uuid())
  productId  String
  reviewText String
  rating     Int
  sentiment  String?
  aspect     String   @default("lainnya")
  reviewDate DateTime

  product Product @relation(fields: [productId], references: [id])
}

model Sales {
  id        String   @id @default(uuid())
  productId String
  date      DateTime
  quantity  Int

  product Product @relation(fields: [productId], references: [id])
  
  @@unique([productId, date])
}

model Prediction {
  id             String   @id @default(uuid())
  productId      String
  predictedSales Int
  predictionDate DateTime
  modelVersion   String?

  product Product @relation(fields: [productId], references: [id])
}

 model Insight {
  id         String  @id @default(uuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id])

  summary            String
  executiveSummary   String?   // ← tambah
  insights           Json
  recommendations    Json

  sentimentScore   Float
  dominantIssue    String
  demandTrend      String
  demandGrowthPct  Float
  riskLevel        String
  healthScore      Int

  llmUsed  Boolean  @default(false)
  llmModel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model AiLog {
  id          String   @id @default(uuid())
  productId   String
  prompt      String
  llmResponse String
  status      String
  createdAt   DateTime @default(now())
}

model KeywordSummary {
  id String @id @default(uuid())

  productId String

  word  String
  count Int

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, word])
}

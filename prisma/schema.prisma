generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER @map("user")
  DEMO @map("demo")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  password      String?   // Boleh null karena akan diisi jika login via email/password
  role          String    @default("USER")
  avatar        String?
  isDemo        Boolean   @default(false)
  expiresAt     DateTime?
  emailVerified DateTime? // Untuk verifikasi email (opsional)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relasi NextAuth
  product       Product[]
  notification  Notification[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id        String   @id @default(uuid())
  userId    String
  name      String
  category  String?
  createdAt DateTime @default(now())

  user           User             @relation(fields: [userId], references: [id])
  reviews        Review[]
  sales          Sales[]
  predictions    Prediction[]
  insights       Insight[]
  KeywordSummary KeywordSummary[]
}

model Review {
  id         String   @id @default(uuid())
  productId  String
  reviewText String
  rating     Int
  sentiment  String?
  reviewDate DateTime
  aspect     String?

  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  
  @@unique([productId, reviewText, reviewDate])
}

model Sales {
  id        String   @id @default(uuid())
  productId String
  date      DateTime
  quantity  Int
  promotionFlag Boolean? @default(false)

  product Product @relation(fields: [productId], references: [id])
  
  @@unique([productId, date])
}

model Prediction {
  id             String   @id @default(uuid())
  productId      String
  predictedSales Int
  predictionDate DateTime
  modelVersion   String?

  upperBound      Int?
  lowerBound      Int?

  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

 model Insight {
  id         String  @id @default(uuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id])

  summary            String
  executiveSummary   String?   // ← tambah
  insights           Json
  recommendations    Json

  sentimentScore   Float
  dominantIssue    String
  demandTrend      String
  demandGrowthPct  Float
  riskLevel        String
  healthScore      Int

  confidence        Float?
  confidenceLabel   String?
  confidenceMessage String?
  confidenceColor   String?

  freq         String?  @default("D")
  modelVersion String?

  llmUsed  Boolean  @default(false)
  llmModel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model AiLog {
  id          String   @id @default(uuid())
  productId   String
  prompt      String
  llmResponse String
  status      String
  createdAt   DateTime @default(now())
}

model KeywordSummary {
  id        String   @id @default(uuid())
  productId String
  word      String
  count     Int
  category  String   @default("lainnya")   // ← tambahkan ini

  product   Product  @relation(fields: [productId], references: [id])

  @@unique([productId, word])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  message     String
  type        String   // 'info', 'success', 'warning', 'error'
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}